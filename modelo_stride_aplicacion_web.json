              "description": "Servidor interno que procesa la lógica de negocio, valida solicitudes y accede a PostgreSQL.",
              "threats": [
                {
                  "ruleId": "96de552c-aba9-4bd6-9ba3-4ef72366f53f",
                  "title": "Negación de operaciones realizadas",
                  "type": "Repudiation",
                  "modelType": "STRIDE",
                  "status": "Mitigated",
                  "severity": "Medium",
                  "description": "Un usuario podría negar haber modificado, eliminado o consultado información si el sistema no conserva evidencia verificable.",
                  "mitigation": "Implementar registros de auditoría protegidos con usuario, acción, fecha, hora, IP, resultado e identificador único de solicitud.",
                  "threatId": "c3b80846-3b8d-4af0-ab35-43cb99af6afb"
                },
                {
                  "ruleId": "9207c521-7c13-44d2-9a8f-7833b1ca23e1",
                  "title": "Saturación de la API mediante solicitudes masivas",
                  "type": "Denial of service",
                  "modelType": "STRIDE",
                  "status": "Mitigated",
                  "severity": "High",
                  "description": "Un atacante podría enviar solicitudes masivas o consultas costosas hasta agotar CPU, memoria, conexiones o recursos de la base de datos.",
                  "mitigation": "Aplicar rate limiting, límites de tamaño, timeouts, caché, monitoreo, firewall, límites de conexiones y bloqueo temporal de fuentes abusivas.",
                  "threatId": "fd597178-efac-430f-9723-171e86adf899"
                },
                {
                  "ruleId": "6e5114e2-8fed-46eb-8c84-094d58cc2b35",
                  "title": "Obtención indebida de privilegios administrativos",
                  "type": "Elevation of privilege",
                  "modelType": "STRIDE",
                  "status": "Mitigated",
                  "severity": "Critical",
                  "description": "Un usuario básico podría manipular su token, modificar identificadores o acceder directamente a rutas protegidas para ejecutar funciones administrativas.",
                  "mitigation": "Aplicar RBAC, validar permisos en cada endpoint, principio de mínimo privilegio, protección de rutas administrativas y verificación de firma y vigencia de tokens.",
                  "threatId": "e3cbbad2-d212-4421-aca1-e343243d8831"
                }
              ],
